# =============================================================================
# Tiny RAG 环境变量配置
# 复制本文件为 .env 后再填入真实值
# 通过切换 LLM_PROVIDER / EMBEDDING_PROVIDER 来选择不同后端
# LLM_PROVIDER 支持: lmstudio | ollama | openai | deepseek
# EMBEDDING_PROVIDER 支持: lmstudio | ollama | openai
# =============================================================================

# ---------- 通用 ----------
# 待导入的文档目录。docs/ 是项目说明文档，不建议作为默认导入源。
DOCUMENTS_DIR=./documents
# source 字段的相对路径基准；默认与 DOCUMENTS_DIR 相同。
SOURCE_ROOT=./documents
# 递归导入的文件扩展名，支持逗号或空白分隔。
DOCUMENT_EXTENSIONS=.md,.txt
# 向量库文件（NDJSON 格式，第一行为元数据，之后每行一条 chunk 记录）
VECTOR_STORE=./vector-store.ndjson
# 可选：中间态缓存目录。留空或删除则不启用；启用后会保存派生 records/embedding 矩阵以加速加载。
INTERMEDIATE_DIR=
# 切块参数
CHUNK_SIZE=600
CHUNK_OVERLAP=80
# 检索 topK
TOP_K=4
# 最低相似度阈值（向量已归一化，等价 cosine）。0 表示关闭过滤；建议 0.2~0.4。
MIN_SCORE=0
# 同一 source 在最终 TopK 中最多出现的次数，避免上下文被同一文件占满
PER_SOURCE_LIMIT=2
# 流式输出：1=边生成边打印（默认），0=等模型生成完一次性输出
STREAM=1
# 本地服务监听地址；仅用于 npm run serve
SERVE_HOST=127.0.0.1
SERVE_PORT=8787
# 设置后 /query 与 /reload 需带 Authorization: Bearer <token>；留空则不鉴权
SERVE_AUTH_TOKEN=
# /query 最大并发，超出返回 503
SERVE_MAX_CONCURRENCY=4

# ---------- ingest 性能 ----------
# 单次 embedding 请求批大小；不同 provider 上限不同
EMBED_BATCH_SIZE=32
# 多个 batch 之间的并发上限；OpenAI 类服务可调到 2~4 提速
INGEST_CONCURRENCY=1

# ---------- 网络请求 ----------
# 单次请求超时（毫秒）
REQUEST_TIMEOUT_MS=60000
# 失败重试次数（不含首次请求）
REQUEST_RETRIES=2
# Ollama embedding 并发上限（OpenAI/LM Studio 已批量请求，无需此项）
OLLAMA_EMBED_CONCURRENCY=4
# LLM 采样温度，调试 prompt 时可临时调大/调小
LLM_TEMPERATURE=0.2

# ---------- Provider 选择 ----------
# 嵌入模型与生成模型可以分别使用不同的 provider
LLM_PROVIDER=lmstudio
EMBEDDING_PROVIDER=lmstudio

# =============================================================================
# LM Studio (默认本地 OpenAI 兼容接口)
# 默认地址: http://127.0.0.1:1234/v1
# =============================================================================
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_LLM_MODEL=qwen2.5-7b-instruct
LMSTUDIO_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5

# =============================================================================
# Ollama
# 默认地址: http://127.0.0.1:11434
# =============================================================================
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_LLM_MODEL=qwen2.5:7b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# =============================================================================
# DeepSeek (OpenAI 兼容 Chat API；通常只用于 LLM)
# base_url: https://api.deepseek.com
# 如使用 DeepSeek 做 LLM，建议将 LLM_PROVIDER=deepseek；
# embedding 仍使用 openai / lmstudio / ollama 之一。
# =============================================================================
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_LLM_MODEL=deepseek-v4-pro

# =============================================================================
# OpenAI (官方 / 兼容 API)
# 任意兼容 OpenAI 协议的服务都可以填到这里
# =============================================================================
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
